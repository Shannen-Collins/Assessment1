<Window x:Class="Assessment1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Assessment1"
        mc:Ignorable="d"
        Title="ShannenMovieLibraryMS" Height="600" Width="800">
    <Window.Resources> 
        <!-- define the style for all buttons --> 
        <Style TargetType="Button"> 
            <Setter Property="Background" Value="#66cbff"/> 
            <Setter Property="Foreground" Value="Black"/> 
            <Setter Property="FontSize" Value="14"/> 
            <Setter Property="FontFamily" Value="Gadugi"/> 
            <Setter Property="MinWidth" Value="90"/> 
            <Setter Property="MinHeight" Value="30"/> 
            <Setter Property="Padding" Value="10, 0"/> 
        </Style> 
        <!-- define the style for all textboxes -->
        <Style TargetType="TextBox"> 
            <Setter Property="Foreground" Value="Black"/> 
            <Setter Property="FontSize" Value="14"/> 
            <Setter Property="FontFamily" Value="Gadugi"/> 
            <Setter Property="Margin" Value="150,0,150,10"/>  
            <Setter Property="Height" Value="25"/> 
        </Style> 
        <!-- define the style for all labels -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="14"/> 
            <Setter Property="FontFamily" Value="Gadugi"/> 
            <Setter Property="HorizontalContentAlignment" Value="Center"/> 
            <Setter Property="VerticalContentAlignment" Value="Center"/> 
        </Style>    

    </Window.Resources> 
    <!-- main grid with light blue background --> 
    <Grid Background="#d9effa">
        <!-- defines grid sizing --> 
        <Grid.RowDefinitions> 
            <!-- search row defined --> 
            <RowDefinition Height="Auto"/> 
            <!-- datagrid row defined --> 
            <RowDefinition Height="*"/> 
            <!-- buttons row defined --> 
            <RowDefinition Height="Auto"/> 
        </Grid.RowDefinitions> 

        <!-- search row --> 
        <WrapPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40, 40, 40, 10">
            <TextBox x:Name="txtSearch" Width="300" Margin="0,10,20,10"/>
            <Button x:Name="btnSearchTitle" Content="Search by Title" Margin="0,10,10,10" Click="btnSearchTitle_Click"/>
            <Button x:Name="btnSearchID" Content="Search by Movie ID" Margin="0,10,10,10" Click="btnSearchID_Click"/>
            <Button x:Name="btnShowAll" Content="Show All" Margin="0,10,10,10" Click="btnShowAll_Click"/>
        </WrapPanel>
        
        <!-- datagrid row  --> 
        <DataGrid x:Name="dtgMovies" Grid.Row="1" IsReadOnly="True" Margin="40,10,40,10" FontSize="16" FontFamily="Gadugi"/>

        <!-- buttons row  --> 
        <WrapPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="40,10,40,40">
            <Button x:Name="btnAddMovie" Content="Add Movie" Margin="0,10,10,10" Click="btnAddMovie_Click"/>  
            <Button x:Name="btnSortTitle" Content="Sort by Title" Margin="0,10,10,10" Click="btnSortTitle_Click"/>
            <Button x:Name="btnSortYear" Content="Sort by Year" Margin="0,10,10,10" Click="btnSortYear_Click"/>
            <Button x:Name="btnImport" Content="Import Movie List" Margin="0,10,10,10"/>  
            <Button x:Name="btnExport" Content="Export Movie List" Margin="0,10,10,10"/> 
            <Button x:Name="btnBorrow" Content="Borrow Movie" Margin="0,10,10,10"/>
            <Button x:Name="btnReturn" Content="Return Movie" Margin="0,10,10,10"/>  
            <Button x:Name="btnBorrowHistory" Content="View Borrow History" Margin="0,10,10,10"/> 
        </WrapPanel>
   
        <!-- Add Movie pop up panel --> 
        <Grid x:Name="addPanel" Grid.RowSpan="3" Background="#80000000" Visibility="Collapsed">
            <Border CornerRadius="10" Background="#d9effa" Width="600" HorizontalAlignment="Center" VerticalAlignment="Center"> 
                <StackPanel Margin="20"> 
                    <Label Content="Enter in the New Movie Details Below" FontWeight="Bold" FontSize="20" Margin="10,10,10,15"/> 
                    <Label Content="Movie ID (must be unique)"/> 
                    <TextBox x:Name="txtMovieID"/> 
                    <Label Content="Movie Title"/> 
                    <TextBox x:Name="txtTitle"/> 
                    <Label Content="Movie Director"/> 
                    <TextBox x:Name="txtDirector"/> 
                    <Label Content="Movie Genre"/> 
                    <TextBox x:Name="txtGenre"/> 
                    <Label Content="Movie Release Year"/> 
                    <TextBox x:Name="txtYear"/> 
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10, 10, 10, 20"> 
                        <Button Content="Back" Click="btnAddBack_Click" Margin="10"/> 
                        <Button Content="Save" Click="btnAddSave_Click" Margin="10"/> 
                    </StackPanel>
                </StackPanel> 
            </Border>
        </Grid>  
    </Grid>  
</Window>
